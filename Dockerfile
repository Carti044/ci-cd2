# Базовый образ: slim = лёгкий, без лишнего
FROM python:3.12-slim

# Рабочая директория внутри контейнера
WORKDIR /app

# Сначала копируем только requirements — это слой кэшируется,
# и при изменении кода зависимости не переустанавливаются заново
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Теперь копируем остальной код
COPY . .

# Документируем порт, который слушает приложение
EXPOSE 8080

# Команда запуска контейнера
CMD ["python", "app.py"]
